<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>
    <!-- UseWPF pulls in WindowsBase/Dispatcher used by PipeIPC, HttpTask,
         UpdateInstaller, UpdateDownloader, AppLog, WuAgent -->
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>wu.ico</ApplicationIcon>
    <AssemblyName>wumgr</AssemblyName>
    <RootNamespace>wumgr</RootNamespace>
    <Platforms>AnyCPU</Platforms>
    <!-- AssemblyInfo.cs defines these manually; suppress SDK auto-generation -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Suppress obsolete WinForms API warnings (MenuItem/ContextMenu still functional) -->
    <NoWarn>$(NoWarn);WFDEV006;CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- ServiceController / ServiceStartMode are in a separate package on .NET 10 -->
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.6" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pre-built interop assemblies (generated from COM type libraries via tlbimp).
         Using file references instead of COMReference so dotnet/Roslyn can resolve them. -->
    <Reference Include="Interop.TaskScheduler">
      <HintPath>Interop\Interop.TaskScheduler.dll</HintPath>
    </Reference>
    <Reference Include="Interop.WUApiLib">
      <HintPath>Interop\Interop.WUApiLib.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <!-- Use Update (not Include) to add metadata without duplicating SDK auto-inclusion -->
    <EmbeddedResource Update="WuMgr.resx">
      <DependentUpon>WuMgr.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
      <SubType>Designer</SubType>
    </EmbeddedResource>
    <None Include="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
    <None Include="app.manifest">
      <SubType>Designer</SubType>
    </None>
    <None Include="App.config">
      <SubType>Designer</SubType>
    </None>
  </ItemGroup>
</Project>
